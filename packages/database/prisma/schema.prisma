// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NodeType {
  question
  answer
}

enum Role {
  user
  assistant
}

enum BlockType {
  heading
  paragraph
  code
  bullet_list
  numbered_list
  quote
  callout
}

enum CalloutType {
  info
  warning
  success
  error
}

enum WorkspaceMemberRole {
  owner
  admin
  member
  viewer
}

enum AiRequestStatus {
  pending
  streaming
  completed
  failed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspaceMembers WorkspaceMember[]
  conversations    Conversation[]
  nodes            Node[]
  aiRequests       AiRequest[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       WorkspaceMember[]
  conversations Conversation[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String              @map("workspace_id")
  userId      String              @map("user_id")
  role        WorkspaceMemberRole @default(member)
  joinedAt    DateTime            @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Conversation {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerId     String   @map("owner_id")
  workspaceId String?  @map("workspace_id")
  isFavorite  Boolean  @default(false) @map("is_favorite")
  tags        String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace  Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  nodes      Node[]
  aiRequests AiRequest[]

  @@index([ownerId])
  @@index([workspaceId])
  @@index([createdAt(sort: Desc)])
  @@map("conversations")
}

model Node {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  parentNodeId   String?  @map("parent_node_id")
  parentBlockId  String?  @map("parent_block_id")
  createdById    String   @map("created_by_id")
  type           NodeType
  role           Role
  content        String?
  depth          Int      @default(0)
  path           String
  // Position among siblings — used for drag reordering
  position       Int      @default(0)
  isCollapsed    Boolean  @default(false) @map("is_collapsed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent       Node?        @relation("NodeChildren", fields: [parentNodeId], references: [id], onDelete: Cascade)
  children     Node[]       @relation("NodeChildren")
  parentBlock  Block?       @relation("BlockBranches", fields: [parentBlockId], references: [id], onDelete: SetNull)
  createdBy    User         @relation(fields: [createdById], references: [id])
  blocks       Block[]
  aiRequests   AiRequest[]

  @@index([conversationId])
  @@index([parentNodeId])
  @@index([parentBlockId])
  @@index([conversationId, depth])
  @@index([path])
  @@index([parentNodeId, position])
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("nodes")
}

model Block {
  id          String      @id @default(cuid())
  nodeId      String      @map("node_id")
  type        BlockType
  content     String      @default("")
  position    Int
  language    String?
  calloutType CalloutType? @map("callout_type")
  createdAt   DateTime    @default(now()) @map("created_at")

  node     Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  items    BlockItem[]
  branches Node[]      @relation("BlockBranches")

  @@index([nodeId])
  @@index([nodeId, position])
  @@map("blocks")
}

model BlockItem {
  id       String @id @default(cuid())
  blockId  String @map("block_id")
  content  String
  position Int

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@index([blockId, position])
  @@map("block_items")
}

model AiRequest {
  id             String          @id @default(cuid())
  conversationId String          @map("conversation_id")
  nodeId         String?         @map("node_id")
  userId         String          @map("user_id")
  status         AiRequestStatus @default(pending)
  model          String
  promptTokens   Int             @default(0) @map("prompt_tokens")
  outputTokens   Int             @default(0) @map("output_tokens")
  durationMs     Int?            @map("duration_ms")
  error          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  completedAt    DateTime?       @map("completed_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  node         Node?        @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("ai_requests")
}
